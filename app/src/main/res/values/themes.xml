<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ════════════════════════════════════════════════════
         BASE THEME
    ════════════════════════════════════════════════════ -->
    <style name="Theme.BookLoop" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/nav_bar_bg</item>
        <item name="android:fontFamily">sans-serif</item>
        <!-- Default Material card style -->
        <item name="materialCardViewStyle">@style/Widget.BookLoop.Card</item>
        <!-- Default button style -->
        <item name="materialButtonStyle">@style/Widget.BookLoop.Button.Primary</item>
        <!-- Default TextInputLayout style -->
        <item name="textInputStyle">@style/Widget.BookLoop.TextInputLayout</item>
    </style>

    <!-- ════════════════════════════════════════════════════
         SPLASH THEME  (immersive full-screen)
    ════════════════════════════════════════════════════ -->
    <style name="Theme.BookLoop.Splash" parent="Theme.BookLoop">
        <item name="android:windowBackground">@color/primary_dark</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>
    </style>

    <!-- ════════════════════════════════════════════════════
         BUTTONS
    ════════════════════════════════════════════════════ -->
    <style name="Widget.BookLoop.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="cornerRadius">50dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="elevation">4dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Widget.BookLoop.Button.Accent" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="cornerRadius">50dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="elevation">4dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Widget.BookLoop.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="backgroundTint">@android:color/transparent</item>
        <!-- primary_light is overridden to a bright blue in dark mode — keeps outlined buttons visible -->
        <item name="strokeColor">@color/primary_light</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/primary_light</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="cornerRadius">50dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.BookLoop.Button.Danger" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/error</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="cornerRadius">50dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="elevation">4dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- ════════════════════════════════════════════════════
         TEXT INPUT
    ════════════════════════════════════════════════════ -->
    <style name="Widget.BookLoop.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/divider</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <!-- primary_light is overridden in values-night/colors.xml to be readable on dark surfaces -->
        <item name="hintTextColor">@color/primary_light</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxBackgroundColor">@color/surface</item>
    </style>

    <!-- ════════════════════════════════════════════════════
         CARD
    ════════════════════════════════════════════════════ -->
    <style name="Widget.BookLoop.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">6dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- ════════════════════════════════════════════════════
         SECTION HEADER TEXT
    ════════════════════════════════════════════════════ -->
    <style name="TextAppearance.BookLoop.SectionHeader" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- ════════════════════════════════════════════════════
         BOTTOM NAV
    ════════════════════════════════════════════════════ -->
    <style name="Widget.BookLoop.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/nav_bar_bg</item>
        <item name="itemIconTint">@color/nav_inactive</item>
        <item name="itemTextColor">@color/nav_inactive</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.BookLoop.BottomNavIndicator</item>
        <item name="elevation">12dp</item>
    </style>

    <style name="Widget.BookLoop.BottomNavIndicator" parent="">
        <item name="android:color">@color/primary_surface</item>
    </style>

</resources>
