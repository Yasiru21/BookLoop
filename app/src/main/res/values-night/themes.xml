<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Night-mode theme overrides.
        Inherits everything from values/themes.xml; only differences are listed here.
    -->
    <style name="Theme.BookLoop" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Dark mode: status bar icons MUST be white, not dark -->
        <item name="android:windowLightStatusBar">false</item>
        <!-- Keep status/nav bar colours in sync with the dark background -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/nav_bar_bg</item>
    </style>

    <!-- Splash stays dark regardless of theme -->
    <style name="Theme.BookLoop.Splash" parent="Theme.BookLoop">
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
