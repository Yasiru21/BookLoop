<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon for Android 8.0+ (API 26+).
    Background: white (matches the PNG's white outer area).
    Foreground: the full AI-generated PNG icon.
    When the launcher clips to circle/squircle, the white corners are
    clipped away and the deep-blue circular design is revealed.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/white" />
    <foreground android:drawable="@drawable/ic_launcher_full" />
</adaptive-icon>
