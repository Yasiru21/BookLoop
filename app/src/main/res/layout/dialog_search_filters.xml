<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <!-- ── Drag handle ─────────────────────────────────────────── -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        android:background="#CBD5E1"
        android:alpha="0.6" />

    <!-- ── Header row ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎛 Advanced Filters"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearAll"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Clear All"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cornerRadius="50dp"
            app:elevation="0dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider" android:layout_marginBottom="20dp"/>

    <!-- ── Price Range ─────────────────────────────────────────── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingBottom="12dp"
        android:text="💰  Price Range (Rs.)"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Min price input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilMinPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Min"
            app:prefixText="Rs. "
            style="@style/Widget.BookLoop.TextInputLayout">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMinPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:imeOptions="actionNext" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:text="—"
            android:textColor="@color/text_hint"
            android:textSize="18sp" />

        <!-- Max price input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilMaxPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Max"
            app:prefixText="Rs. "
            style="@style/Widget.BookLoop.TextInputLayout">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMaxPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:imeOptions="actionDone" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <!-- Quick-pick price presets (horizontally scrollable) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/presetUnder500"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="Under Rs.500"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="6dp"
                app:backgroundTint="@color/surface_variant"
                app:cornerRadius="50dp"
                app:elevation="0dp"
                style="@style/Widget.MaterialComponents.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset500to2000"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="Rs.500–2000"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="6dp"
                app:backgroundTint="@color/surface_variant"
                app:cornerRadius="50dp"
                app:elevation="0dp"
                style="@style/Widget.MaterialComponents.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/preset2000to5000"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="Rs.2000–5000"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="6dp"
                app:backgroundTint="@color/surface_variant"
                app:cornerRadius="50dp"
                app:elevation="0dp"
                style="@style/Widget.MaterialComponents.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/presetOver5000"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="Rs.5000+"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="4dp"
                app:backgroundTint="@color/surface_variant"
                app:cornerRadius="50dp"
                app:elevation="0dp"
                style="@style/Widget.MaterialComponents.Button" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"/>

    <!-- ── Availability ────────────────────────────────────────── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingBottom="12dp"
        android:text="📦  Availability"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

    <!-- Availability chips: HorizontalScrollView prevents text from wrapping/cropping -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/statusAll"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:text="All"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="8dp"
                app:backgroundTint="@color/primary"
                app:cornerRadius="50dp"
                app:elevation="2dp"
                style="@style/Widget.MaterialComponents.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/statusAvailable"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:text="Available"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="8dp"
                app:backgroundTint="@color/surface_variant"
                app:cornerRadius="50dp"
                app:elevation="0dp"
                style="@style/Widget.MaterialComponents.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/statusReserved"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:text="Reserved"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="8dp"
                app:backgroundTint="@color/surface_variant"
                app:cornerRadius="50dp"
                app:elevation="0dp"
                style="@style/Widget.MaterialComponents.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/statusSold"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:text="Sold"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@color/surface_variant"
                app:cornerRadius="50dp"
                app:elevation="0dp"
                style="@style/Widget.MaterialComponents.Button" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"/>

    <!-- ── Apply button ────────────────────────────────────────── -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApplyFilters"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:text="Apply Filters"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:backgroundTint="@color/primary"
        app:cornerRadius="50dp"
        app:elevation="4dp"
        style="@style/Widget.MaterialComponents.Button" />

</LinearLayout>
